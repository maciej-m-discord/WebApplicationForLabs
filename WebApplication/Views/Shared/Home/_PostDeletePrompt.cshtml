<div id ="postDeletePrompt" uk-modal>
    <div class="uk-modal-dialog relative mx-auto bg-slate-800 rounded-lg shadow-xl w-[400px]">
        <!-- Modal Header -->
        <div class="p-6">
            <h2 class="text-xl font-semibold" style="color: white!important;">Confirm Deletion</h2>
        </div>
        <!-- Modal Body -->
        <div class="p-6 py-0">
            <p style="color: white!important;">Are you sure you want to delete this post?</p>
        </div>
        <!-- Modal Footer-->
        <div class="flex justify-end p-6 text-sm font-medium gap-3" style="color: white!important;">
            <button type="button" class="px-5 py-1.5 rounded-md bg-slate-700 uk-modal-close custom-bg-dark">Cancel</button>
            <form asp-controller="Home" asp-action="PostDelete">
                <input type="hidden" name="postId" id="deletePromptPostId" value=""/>
                <button type="submit" class="px-5 py-1.5 rounded-md custom-change-color bg-slate-700 hover:!bg-red-50">Delete</button>
            </form>
        </div>
        
        <!-- Close Button -->
        <button type="button" class="p-2 absolute right-0 top-0 m-3 uk-modal-close">
            <svg fill="#FFFFFF" version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" 
                 width="25px" height="25px" viewBox="0 0 512 512" enable-background="new 0 0 512 512" xml:space="preserve">
                <polygon points="335.188,154.188 256,233.375 176.812,154.188 154.188,176.812 233.375,256 154.188,335.188 176.812,357.812 
	                    256,278.625 335.188,357.812 357.812,335.188 278.625,256 357.812,176.812 "/>
                <path d="M256,0C114.609,0,0,114.609,0,256s114.609,256,256,256s256-114.609,256-256S397.391,0,256,0z M256,472
	                    c-119.297,0-216-96.703-216-216S136.703,40,256,40s216,96.703,216,216S375.297,472,256,472z"/>
            </svg>
        </button>
    </div>
</div>