@inject UserManager<User> UserManager
@model Post
@{
    var loggedInUser = await UserManager.GetUserAsync(User);
    var profilePictureUrl = loggedInUser?.ProfilePictureUrl;
    int loggedInUserId = int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int result) ? result : 0;
    
    TimeSpan timeSpanSincePosted = DateTime.UtcNow.Subtract(Model.CreatedAt);
    string displayTime = "";
    if (timeSpanSincePosted.Days >= 365)
    {
        displayTime = $"{timeSpanSincePosted.Days/365} y ago";
    } 
    else if (timeSpanSincePosted.Days >= 30)
    {
        displayTime = $"{timeSpanSincePosted.Days/30} m ago";
    }
    else if (timeSpanSincePosted.TotalDays >= 1)
    {
        displayTime = $"{timeSpanSincePosted.Days} d ago";
    }
    else if (timeSpanSincePosted.TotalHours >= 1)
    {
        displayTime = $"{timeSpanSincePosted.Hours} h ago";
    } 
    else if (timeSpanSincePosted.TotalMinutes >= 1)
    {
        displayTime = $"{timeSpanSincePosted.Minutes} m ago";
    }
    else
    {
        displayTime = $"Just now";
    }

    bool showAllComments = ViewData["ShowAllComment"] as bool? ?? false;
    bool showDetails = ViewData["ShowDetails"] as bool? ?? true;
}
<div id="post-@Model.Id" class="rounded-xl shadow-sm text-sm font-medium bg-slate-800" style="outline:2px solid!important; outline-color:rgb(49,101,84) !important; ">
    @* Post heading *@
    <div class="flex gap-3 sm:p-4 p-2.5 text-sm font-medium rounded-xl">
        <a asp-controller="User" asp-action="Details" asp-route-userId="@Model.UserId" class="w-9 h-9 overflow-hidden rounded-full flex items-center justify-center">
            <img src="@(string.IsNullOrEmpty(Model.User.ProfilePictureUrl) ? Url.Content("~/images/avatar/user.png") : Url.Content(Model.User.ProfilePictureUrl))" class="w-full h-full object-cover rounded-full shadow"/>
        </a>
        <div class="flex-1">
            <a asp-controller="User" asp-action="Details" asp-route-userId="@Model.UserId">
                <h4 style="color:#FFFFFF!important;">@Model.User.FullName</h4>
                <div class="text-xs text-gray-400" title="@Model.CreatedAt.ToLocalTime().ToString("HH:mm dd-MM-yyyy")">@displayTime</div>
            </a>
        </div>
        <div class="-mr-1">
            <button type="button" class="w-8 h-8 button-icon custom-bg-dark">
                <ion-icon class="text-xl" style="color:#ffffff!important;" name="ellipsis-horizontal"></ion-icon>
            </button>
            <div class="w-[245px] post-options-dropdown bg-slate-800 border1 custom-border-color" uk-dropdown="pos: bottom-right; animation: uk-animation-scale-up uk-transform-origin-top-right; animate-out:true; mode:click">
                <form asp-controller="Home" asp-action="AddPostReport">
                    <input type="hidden" name="postId" value="@Model.Id"/>
                    <button type="@(Model.Reports.Any(n => n.UserId == loggedInUserId)? "button" : "submit")" class="icon-link @(Model.Reports.Any(n => n.UserId == loggedInUserId)? "" : "custom-bg-dark") rounded-[20px]" style="color:@(Model.Reports.Any(n => n.UserId == loggedInUserId)? "#ff0000" : "#ffffff")!important;">
                        <ion-icon class="text-xl shrink-0" name="@(Model.Reports.Any(n => n.UserId == loggedInUserId)? "flag" : "flag-outline")" style="color:@(Model.Reports.Any(n => n.UserId == loggedInUserId)? "#ff0000" : "#ffffff")!important;"></ion-icon> @(Model.Reports.Any(n => n.UserId == loggedInUserId)? "Post reported" : "Report")
                    </button>
                </form>
                <hr />
                
                @if (Model.UserId == loggedInUserId || User.IsInRole(AppRoles.Admin))
                {
                    <form asp-controller="Home" asp-action="TogglePostVisibility">
                        <input type="hidden" name="postId" value="@Model.Id"/>
                        <button type="submit" class="icon-link custom-bg-dark rounded-[20px]" style="color: #ffffff!important;">
                            <ion-icon class="text-xl" name="@(Model.IsPrivate?"lock-closed" : "lock-closed-outline")" style="color: @(Model.IsPrivate?"#ff0000" : "#ffffff")!important;"></ion-icon>@(Model.IsPrivate? "Set as public" : "Set as private")
                        </button>
                    </form>
                    <hr/>
                    <button type="button" onclick="openPostDeletePrompt('@Model.Id')"  class="delete-post-btn hover:!bg-red-50 custom-change-color rounded-[20px]" style="color: #ffffff;">
                        <ion-icon class="text-xl custom-change-color" name="trash-bin-outline" style="color:inherit;"></ion-icon> Delete post
                    </button>
                }
            </div>
        </div>
    </div>
    @* Post content *@
    <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
        <div class="sm:px4 p-2 pt-0 w-full custom-bg-dark">
            <p class="font-normal" style="padding-left: 12px; color: #ffffff!important;">
                @Model.Content
            </p>
        </div>
    </a>
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <a href="@Model.ImageUrl" class="story-link" data-gallery="posts" data-src="@Model.ImageUrl" aria-label="open image">
            <div class="relative w-full lg:h-96 h-full sm:px-4">
                <img src="@Model.ImageUrl" class="sm:rounded-lg w-full h-full object-cover" loading="lazy" />
            </div>
        </a>
    }
    @* Icons *@
    <div class="sm:p-4 p-2.5 flex items-center gap-16 text-xs font-semibold">
        <div class="flex items-center gap-2 ">
            <a class="button-icon custom-bg-dark">
                <ion-icon class="text-lg" style="color:#ffffff!important;" name="chatbubble-ellipses-outline"></ion-icon>
            </a>
            <a href="#" style="color:#ffffff!important;">
                @Model.Comments.Count
            </a>
        </div>
        <div class="flex items-center gap-2">
            <form asp-controller="Home" asp-action="TogglePostLike">
                @Html.AntiForgeryToken()
                <input type="hidden" name="postId" value="@Model.Id"/>
                <button type="submit" class="button-icon like-button  @(Model.Likes.Any(u => u.UserId == loggedInUserId) ? "text-red-500" : "text-white") custom-bg-dark">
                    <ion-icon class="text-lg" name="@(Model.Likes.Any(n => n.UserId == loggedInUserId) ? "heart" : "heart-outline")"></ion-icon>
                </button>
            </form>
            <a href="#" style="color:#ffffff!important;">
                @Model.Likes.Count
            </a>
        </div>

        <div class="ml-auto"></div>
        <div>
            <form asp-controller="Home" asp-action="TogglePostBookmark">
                <input type="hidden" name="postId" value="@Model.Id"/>
                <button type="submit" class="button-icon bookmark-button ml-auto custom-bg-dark">
                    <ion-icon class="text-lg" style="@(Model.Bookmarks.Any(n => n.UserId == loggedInUserId) ? "color:#90f2ad" : "color:#ffffff")!important;" name="@(Model.Bookmarks.Any(n => n.UserId == loggedInUserId) ? "bookmark" : "bookmark-outline")"></ion-icon>
                </button>
            </form>
            @* <a href="#" style="color:#ffffff!important;"> *@
            @*     @Model.Bookmarks.Count *@
            @* </a> *@
        </div>
       
    </div>
    @if (showDetails)
    {
    @* Add comment *@
    <div class="p-2.5 border-t custom-border-color font-normal space-y-3 relative">
        @if (Model.Comments != null)
        {
           
            var commentsQuery = showAllComments ? Model.Comments.OrderBy(n => n.CreatedAt) : Model.Comments.OrderBy(n => n.CreatedAt).TakeLast(3);
            
            foreach(var comment in commentsQuery)
            {
                TimeSpan timeSpanSincePostedComment = DateTime.UtcNow.Subtract(comment.CreatedAt);
                string displayTimeComment = "";
                if (timeSpanSincePostedComment.Days >= 365)
                {
                    displayTimeComment = $"{timeSpanSincePostedComment.Days / 365} y ago";
                }
                else if (timeSpanSincePostedComment.Days >= 30)
                {
                    displayTimeComment = $"{timeSpanSincePostedComment.Days / 30} m ago";
                }
                else if (timeSpanSincePostedComment.TotalDays >= 1)
                {
                    displayTimeComment = $"{timeSpanSincePostedComment.Days} d ago";
                }
                else if (timeSpanSincePostedComment.TotalHours >= 1)
                {
                    displayTimeComment = $"{timeSpanSincePostedComment.Hours} h ago";
                }
                else if (timeSpanSincePostedComment.TotalMinutes >= 1)
                {
                    displayTimeComment = $"{timeSpanSincePostedComment.Minutes} m ago";
                }
                else
                {
                    displayTimeComment = $"Just now";
                }
                var commenter = comment.User;
                var commenterName = commenter?.FullName ?? "Unknown";
                var commenterAvatar = !string.IsNullOrEmpty(commenter?.ProfilePictureUrl) ? commenter.ProfilePictureUrl : Url.Content("~/images/avatar/user.png");
                <div class="flex items-start gap-3 relative bg-slate-800 rounded-[20px]">
                    <a asp-controller="User" asp-action="Details" asp-route-userId="@comment.UserId" class="w-6 h-6 overflow-hidden rounded-full relative shrink-0 flex items-center justify-center" style="margin-top:6px;">
                        <img src="@commenterAvatar" class="w-full h-full object-cover rounded-full shadow"/>
                    </a>
                    <div class="flex-1">
                        <div class="flex justify-content-between">
                            <a class="font-medium inline-block flex-grow" asp-controller="User" asp-action="Details" asp-route-userId="@comment.UserId" style="color: #ffffff!important;">@commenterName</a>
                            <small class="text-xs text-gray-400" title="@comment.CreatedAt.ToLocalTime().ToString("HH:mm dd-MM-yyyy")" style="margin-right:9px;">@displayTimeComment</small>
                        </div>
                        <div class="flex items-center justify-between">
                            <p class="mt-0.5" style="color:#ffffff!important;">
                                @comment.Content
                            </p>
                            @if (comment.UserId == loggedInUserId)
                            {
                                <form asp-controller="Home" asp-action="RemovePostComment" class="remove-comment-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@comment.Id"/>
                                    <input type="hidden" name="postId" value="@comment.PostId"/>
                                    <button type="submit" class="ml-2 hover:!bg-red-50 custom-change-color rounded-full" title="Delete" style="padding:0px; margin-bottom: 0px; color:#ffffff;">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        @if (Model.Comments.Count > 3 && !showAllComments)
        {
            <div class="p1.5 custom-bg-dark" style="color: white!important;">
                <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
                    Show all comments
                </a>
            </div>
        }
    </div>
    <form asp-controller="Home" asp-action="AddPostComment" class="add-comment-form">
        @Html.AntiForgeryToken()
        <div class="sm:px-4 sm:py-3 p-2.5 border-t border-gray-100 flex items-center gap-1">
            <a asp-controller="User" asp-action="Details" asp-route-userId="@loggedInUserId" class="w-6 h-6 overflow-hidden rounded-full relative shrink-0 flex items-center justify-center">
                <img src="@(string.IsNullOrEmpty(profilePictureUrl) ? Url.Content("~/images/avatar/user.png") : profilePictureUrl)" class="w-full h-full object-cover object-center rounded-full shadow"/>
            </a>

            <input type="hidden" name="postId" value="@Model.Id"/>
            <div class="flex-1 relative overflow-hidden h-10">
                <textarea name="content" placeholder="Write your reply" rows="1" class="w-full resize-none !bg-transparent rounded-full px-4 py-2 focus:!border-transparent focus:!ring-transparent" style="background-color: #40826d!important; margin-left:12px; width:98%;"></textarea>
            </div>
            <button type="submit" class="text-sm rounded-full py-1.5 px-3.5 bg-secondary custom-bg-dark bg-slate-900" style="color:#ffffff!important;">Comment</button>

        </div>
    </form>
    }
</div>
