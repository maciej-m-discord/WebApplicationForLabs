<script type="module">
document.addEventListener('DOMContentLoaded', () => {
  const selector = 'a.story-link[data-gallery="posts"]';

  function ensureStyle() {
    if (document.getElementById('postSinglePreviewStyles')) return;
    const css = `
      /* overlay fills the visual viewport and respects safe areas */
      #postSinglePreviewOverlay{
        position:fixed;
        inset:0;
        height:100dvh;
        display:flex;
        align-items:center;
        justify-content:center;
        background:rgba(0,0,0,0.35);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        z-index:99999;
        opacity:0;
        pointer-events:none;
        transition:opacity .18s ease;
        padding: max(env(safe-area-inset-top), 12px) max(env(safe-area-inset-right), 12px) max(env(safe-area-inset-bottom), 12px) max(env(safe-area-inset-left), 12px);
        box-sizing: border-box;
      }
      #postSinglePreviewOverlay.open{
        opacity:1;
        pointer-events:auto;
      }

      /* inner container now shrink-wraps the image instead of spanning nearly full width */
      #postSinglePreviewOverlay .preview-inner{
        position:relative;
        width: auto; /* <-- allow shrink-wrapping so side clicks hit the overlay */
        max-width: calc(100vw - 24px);
        max-height: calc(100dvh - 24px);
        display:flex;
        align-items:center;
        justify-content:center;
        box-sizing: border-box;
        overflow: hidden;
        padding: 6px; /* small gap so clicking near image on the sides is treated as outside the image */
      }

      /* ensure image never exceeds the available space */
      #postSinglePreviewOverlay img{
        display:block;
        width:auto;
        height:auto;
        max-width: calc(100vw - 48px);
        max-height: calc(100dvh - 48px);
        object-fit: contain;
        border-radius:8px;
        box-shadow:0 10px 40px rgba(0,0,0,0.6);
        background:transparent;
        cursor:zoom-out;
      }

      /* close button remains inside the safe area */
      #postSinglePreviewOverlay .pg-close{
        position:absolute;
        top: calc(max(env(safe-area-inset-top), 12px));
        right: calc(max(env(safe-area-inset-right), 12px));
        background:transparent;
        border:0;
        color:#fff;
        font-size:28px;
        line-height:1;
        padding:6px;
        cursor:pointer;
        z-index:2;
      }

      /* ensure story link uses pointer cursor */
      a.story-link { cursor: pointer; }

      body.post-preview-open{overflow:hidden;}
    `;
    const s = document.createElement('style');
    s.id = 'postSinglePreviewStyles';
    s.textContent = css;
    document.head.appendChild(s);
  }

  function createOverlay() {
    let overlay = document.getElementById('postSinglePreviewOverlay');
    if (overlay) return overlay;

    overlay = document.createElement('div');
    overlay.id = 'postSinglePreviewOverlay';
    overlay.innerHTML = `
      <div class="preview-inner" role="dialog" aria-modal="true">
        <button class="pg-close" aria-label="close">&times;</button>
        <img alt="preview image" />
      </div>
    `;
    document.body.appendChild(overlay);

    const btn = overlay.querySelector('.pg-close');
    const img = overlay.querySelector('img');

    btn.addEventListener('click', close);

    // clicking the dimmed background (overlay itself) closes the preview
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    // clicking the image will also close (keeps simple UX); remove if undesired
    img.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('open')) return;
      if (e.key === 'Escape') close();
    });

    return overlay;
  }

  function openPreview(src, alt) {
    const overlay = createOverlay();
    const img = overlay.querySelector('img');
    img.src = '';
    img.alt = alt || 'image preview';

    const tmp = new Image();
    tmp.onload = () => {
      // CSS ensures the image is constrained to the visible viewport
      img.src = tmp.src;
    };
    tmp.src = src;

    overlay.classList.add('open');
    document.body.classList.add('post-preview-open');
  }

  function close() {
    const overlay = document.getElementById('postSinglePreviewOverlay');
    if (!overlay) return;
    overlay.classList.remove('open');
    document.body.classList.remove('post-preview-open');
    setTimeout(() => {
      const img = overlay.querySelector('img');
      if (img) img.src = '';
    }, 200);
  }

  function attachListeners() {
    const anchors = Array.from(document.querySelectorAll(selector));
    anchors.forEach(a => {
      if (a._singlePreviewAttached) return;
      a._singlePreviewAttached = true;
      const src = a.dataset.src || a.getAttribute('href') || '';
      const alt = a.dataset.alt || '';
      // set pointer cursor for clarity
      a.style.cursor = 'pointer';
      a.addEventListener('click', (ev) => {
        ev.preventDefault();
        if (!src) return;
        openPreview(src, alt);
      });
    });
  }

  ensureStyle();
  attachListeners();

  const feedContainer = document.querySelector('.post-highlight')?.parentElement || document.body;
  const mo = new MutationObserver((mutations) => {
    let added = false;
    for (const m of mutations) {
      if (m.addedNodes?.length) { added = true; break; }
    }
    if (added) attachListeners();
  });
  mo.observe(feedContainer, { childList: true, subtree: true });
});
</script>