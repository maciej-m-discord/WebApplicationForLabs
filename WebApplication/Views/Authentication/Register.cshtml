@model RegisterVm
<div class="sm:flex">
    @* Form section *@
    <div class="relative lg:w-[694px] md:w-96 w-full p-10 min-h-screen bg-slate-900 shadow-xl flex items-center pt-6 z-10">
        <div class="w-full lg:max-w-sm mx-auto space-y-10">
            <div>
                <h2 class="text-2xl font-semibold mb-1.5 white" >Register</h2>
                <p class="text-sm text-gray-400 font-normal">Already have an account? <a asp-controller="Authentication" asp-action="Login" class="text-blue-700">Sign in here!</a></p>
            </div>
            <form asp-controller="Authentication" asp-action="Register" method="post" class="space-y-7 text-sm white font-medium">
                <div class="grid grid-cols-2 gap-4 gap-y-5">
                    <div>
                        <label asp-for="FirstName">First Name</label>
                        <div class="mt-2.5">
                            <input id="firstName" asp-for="FirstName" name="firstName" type="text" placeholder="Mark" required="" class="!w-full bg-gray-200"/>
                            <span asp-validation-for="FirstName" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="LastName">Last Name</label>
                        <div class="mt-2.5">
                            <input id="lastName" asp-for="LastName" name="lastName" type="text" placeholder="Smith" required="" class="!w-full bg-gray-200"/>
                            <span asp-validation-for="LastName" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div class="col-span-2">
                        <label asp-for="Email">Email address</label>
                        <div class="mt-2.5">
                            <input id="email" asp-for="Email" name="email" type="email" placeholder="example.1234@site.com" required="" class="!w-full bg-gray-200"/>
                            <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="Password">Password</label>
                        <div class="mt-2.5">
                            <input id="password" asp-for="Password" name="password" type="password" placeholder="Password" required="" class="!w-full bg-gray-200"/>
                            <span asp-validation-for="Password" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword">Confirm Password</label>
                        <div class="mt-2.5">
                            <input id="confirmPassword" asp-for="ConfirmPassword" name="confirmPassword" type="password" placeholder="Confirm Password" required="" class="!w-full bg-gray-200"/>
                            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div class="col-span-2 text-red-500" asp-validation-summary="ModelOnly"></div>
                    <div class="col-span-2 pt-8">
                        <button type="submit" class="button bg-slate-700 white w-full custom-bg-dark">Register</button>
                    </div>
                    <div class="text-center flex items-center gap-6 white col-span-2">
                        <hr class="flex-1 custom-border-color"/>
                        Or register with
                        <hr class="flex-1 custom-border-color"/>
                    </div>

                    <div class="flex gap-2 col-span-2">
                        <a asp-controller="Authentication" asp-action="ExternalLogin" asp-route-provider="Google" class="button flex-1 flex items-center gap-2 bg-slate-700 white text-sm custom-bg-dark">
                            <ion-icon name="logo-google" class="text-lg"></ion-icon>google
                        </a>
                        <a asp-controller="Authentication" asp-action="ExternalLogin" asp-route-provider="GitHub" class="button flex-1 flex items-center gap-2 bg-black white text-sm custom-bg-dark">
                            <ion-icon name="logo-github" class="text-lg"></ion-icon>github
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
    @* Image slider *@
    <div class="flex-1 relative bg-slate-600 max-md:!hidden">
        <div class="relative w-full h-full" tebinter="-1" uk-slideshow="animation: slide; autoplay: true;">
            <ul class="uk-slideshow-items w-full h-full">
                <li class="w-full">
                    <img src="~/images/welcome/welcome2.jpeg" alt="" class="w-full h-full object-cover uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left"/>
                    <div class="absolute bottom-0 w-full uk-transition-slide-bottom-small z-10">
                        <div class="max-w-xl w-full mx-auto pb-32 px-5 z-30 relative">
                            <h4 class="white text-2xl font-semibold mt-7" uk-slideshow-parallax="y:600,0,0">Connect with Friends and meet new ones!</h4>
                            <p class="white text-;g mt-7 leading-8">Bridge the gap between miles and moments-connect with friends and weave memories together, one click at a time</p>
                        </div>
                    </div>
                    <div class="w0full h-96 bg-gradient-to-t from-black absolute bottom-0 left-0"></div>
                </li>
                <li class="w-full">
                    <img src="~/images/welcome/welcome1.jpeg" alt="" class="w-full h-full object-cover uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left"/>
                    <div class="absolute bottom-0 w-full uk-transition-slide-bottom-small z-10">
                        <div class="max-w-xl w-full mx-auto pb-32 px-5 z-30 relative">
                            <h4 class="white text-2xl font-semibold mt-7" uk-slideshow-parallax="y:600,0,0">Connect with Friends and meet new ones!</h4>
                            <p class="white text-;g mt-7 leading-8">Rekindle old ties and spark new ones-your next 'Remember when...' moment is just a friend request away.</p>
                        </div>
                    </div>
                    <div class="w0full h-96 bg-gradient-to-t from-black absolute bottom-0 left-0"></div>
                </li>
            </ul>
            <!-- slide nav -->
            <div class="flex justify-center">
                <ul class="inline-flex flex-wrap justify-center absolute bottom-8 gap-1.5 uk-dotnav uk-slideshow-nav">
                    
                </ul>
            </div>
        </div>
    </div>
</div>