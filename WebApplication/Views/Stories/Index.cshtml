@model List<Story>
<main id="site__main" class="2xl:ml-[--w-side] xl:ml-[--w-side-sm] p-2.5 h-[calc(100vh-var(--m-top))] mt-[--m-top] ">
    <div class="lg:flex 2xl:gap-16 gap-12 mx-auto" id="js-oversized">
        <div class="mx-auto flex-column align-items-center" style="width: 65vw;">
            @* stories *@
            <div class="mb-8">
                <h3 class="font-extrabold text-2xl text-black hidden"></h3>
                
                <div class="relative" tabindex="-1" uk-slider="auto play:true; finite:true" uk-lightbox="">
                    <div class="pt-2 pb-2 uk-slider-container">
                        <ul class="uk-slider-items w-[calc(100%+14px)]" uk-scrollspy="target: > li; cls: uk-animation-scale-up; delay: 20; repeat:true">
                            <li class="md:pr-3 cursor-pointer" uk-scrollspy-class="uk-animation-fade">
                                <div class="md:w-16 md:h-16 w-12 h-12 rounded-full relative border-2 border-dashed grid place-items-center bg-slate-700/20 custom-border-color shrink-0" uk-toggle="target: #create-story">
                                    <ion-icon name="camera" class="text-2xl text-white"></ion-icon>
                                </div>
                            </li>
                            @foreach (var story in Model)
                            {
                                <li class="md:pr-3 pr-2 hover:scale-[1.15] hover:-rotate-2 duration-300">
                                    <a href="@story.ImageUrl">
                                        <div class="md:w-16 md:h-16 w-12 h-12 relative md:border-4 border-2 shadow custom-border-color rounded-full overflow-hidden">
                                            <img src="@story.User.ProfilePictureUrl"/>
                                        </div>
                                    </a>
                                </li>
                            }
                            <li class="md:pr-3 pr-2">
                                <div class="md:w-16 md:h-16 w-12 h-12 bg-slate-700/20 rounded-full animate-pulse">
                                    
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>